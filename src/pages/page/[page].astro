---
import { getCollection } from "astro:content";
import HomeFeedPage from "../../components/HomeFeedPage.astro";
import { buildPostEntries, POSTS_PER_PAGE } from "../../utils/feed.js";

export async function getStaticPaths() {
  const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
  );

  const postEntries = buildPostEntries(allPosts);
  const totalPages = Math.max(1, Math.ceil(postEntries.length / POSTS_PER_PAGE));

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    const start = (page - 1) * POSTS_PER_PAGE;
    const end = start + POSTS_PER_PAGE;

    return {
      params: { page: String(page) },
      props: {
        allPosts,
        posts: postEntries.slice(start, end),
        currentPage: page,
        totalPages
      }
    };
  });
}

const { allPosts, posts, currentPage, totalPages } = Astro.props;
---

<HomeFeedPage posts={posts} currentPage={currentPage} totalPages={totalPages} />
