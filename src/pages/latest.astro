---
import {getCollection} from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import {buildPostEntries} from "../utils/feed.js";

const posts = (await getCollection("posts", ({data}) => !data.draft)).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const postEntries = buildPostEntries(posts);
---

<BaseLayout title="Latest posts | JuniorLog" currentPath="/latest/" randomTheme={true}>
    <hr class="page-separator"/>

    <section class="page-header">
        <h1>Latest posts</h1>
        <p>Newest first.</p>
    </section>

    <hr class="page-separator"/>

    <div class="post-list post-list-shell">
        {
            postEntries.map((post) => (
                    <PostCard
                            slug={post.slug}
                            title={post.data.title}
                            excerptHtml={post.excerptHtml}
                            searchText={post.searchText}
                            author={post.data.author}
                            publishedAt={post.data.publishedAt}
                            readingTime={post.data.readingTime}
                            tags={post.data.tags}
                    />
            ))
        }
    </div>
</BaseLayout>
