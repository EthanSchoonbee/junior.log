---
import {getCollection} from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts", ({data}) => !data.draft)).sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const groupedPosts = Object.entries(
    posts.reduce<Record<string, typeof posts>>((acc, post) => {
        const year = post.data.publishedAt.getFullYear().toString();
        acc[year] ??= [];
        acc[year].push(post);
        return acc;
    }, {})
).sort((a, b) => Number(b[0]) - Number(a[0]));
---

<BaseLayout title="Archive | JuniorLog" currentPath="/archive/" randomTheme={true}>
    <hr class="page-separator"/>

    <section class="page-header">
        <h1>Archive</h1>
        <p>All posts, grouped by year.</p>
    </section>

    <hr class="page-separator"/>

    <div class="archive-list">
        {
            groupedPosts.map(([year, entries]) => (
                    <section class="archive-year">
                        <h2>{year}</h2>
                        <div>
                            {entries.map((post) => (
                                    <a class="archive-row" href={`/posts/${post.slug}/`}>
                                        <time datetime={post.data.publishedAt.toISOString()}>
                                            {post.data.publishedAt.toLocaleDateString("en-ZA", {
                                                month: "short",
                                                day: "numeric"
                                            })}
                                        </time>
                                        <div class="archive-copy">
                                            <strong>{post.data.title}</strong>
                                            <span>{post.data.description}</span>
                                        </div>
                                    </a>
                            ))}
                        </div>
                    </section>
            ))
        }
    </div>
</BaseLayout>
